# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
# Connection pooling URL — used by Prisma at runtime (port 6543)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL — used by Prisma for migrations (port 5432)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"


# ─── Clerk (Authentication) ───────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/


# ─── Groq AI ─────────────────────────────────────────────────────────────────
# Get your free API key from https://console.groq.com/
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── Razorpay (Payments) ─────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx


# ─── App URL ─────────────────────────────────────────────────────────────────
# Local development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production — replace with your Vercel URL after deploying
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
